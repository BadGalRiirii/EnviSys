# --- Django core ---
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Database ---
# Local development (MySQL):
#   DATABASE_URL=mysql://envisys:envisys@localhost:3306/envisys
# Cloud deployment on Render (PostgreSQL):
#   DATABASE_URL=postgres://user:pass@host:5432/envisys
# Leave empty to fall back to SQLite (quick start).
DATABASE_URL=

# --- Email (Brevo, formerly Sendinblue) ---
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=envisys@ustp.edu.ph
# When BREVO_API_KEY is empty, emails are printed to the console instead.

# --- Google OAuth / Drive / Docs integration ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback/
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# --- Encryption key for stored Google OAuth tokens (Fernet) ---
# The default below is fine for localhost only. Generate a real one for
# production with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# --- Frontend URL (used in email links) ---
FRONTEND_URL=http://localhost:5173

# --- Institutional email domain enforced at student signup ---
INSTITUTIONAL_EMAIL_DOMAIN=ustp.edu.ph
